# ============================================================================
# SL Academy Platform - Frontend Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local files with real credentials to version control
# See docs/ENVIRONMENT_VARIABLES.md for detailed documentation
# ============================================================================

# ----------------------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------------------
# Backend API URL (must be accessible from the browser)
# Development: http://localhost:8000
# Staging: https://api-staging.slacademy.com
# Production: https://api.slacademy.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Supabase Configuration (Public)
# ----------------------------------------------------------------------------
# Your Supabase project URL (found in Project Settings > API)
# This is safe to expose to the client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key for client-side operations
# This is safe to expose to the client (RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ----------------------------------------------------------------------------
# Session Configuration (Server-side only)
# ----------------------------------------------------------------------------
# Secret key for encrypting session cookies (MUST be 32+ characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICAL: Must match backend SESSION_SECRET_KEY
# CRITICAL: Use different keys for dev/staging/production
SESSION_SECRET_KEY=your-32-character-secret-key-here-change-this

# Session expiration time in seconds (default: 86400 = 24 hours)
SESSION_MAX_AGE=86400

# ----------------------------------------------------------------------------
# Environment Configuration
# ----------------------------------------------------------------------------
# Node environment: development, production
NODE_ENV=development

# ----------------------------------------------------------------------------
# PWA Configuration
# ----------------------------------------------------------------------------
# Enable PWA features (service worker, offline support)
NEXT_PUBLIC_PWA_ENABLED=true

# Service worker cache name
NEXT_PUBLIC_SW_CACHE_NAME=sl-academy-v1

# ----------------------------------------------------------------------------
# Analytics Configuration (Optional)
# ----------------------------------------------------------------------------
# Google Analytics tracking ID (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ----------------------------------------------------------------------------
# Feature Flags (Optional)
# ----------------------------------------------------------------------------
# Enable AI-powered features
NEXT_PUBLIC_ENABLE_AI_FEATURES=true

# Enable video quality selection
NEXT_PUBLIC_ENABLE_VIDEO_QUALITY=true

# Enable offline mode
NEXT_PUBLIC_ENABLE_OFFLINE=true

# ----------------------------------------------------------------------------
# Performance Configuration
# ----------------------------------------------------------------------------
# API request timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=30000

# Enable request caching
NEXT_PUBLIC_ENABLE_CACHE=true

# Cache revalidation time in seconds
NEXT_PUBLIC_CACHE_REVALIDATE=60

# ----------------------------------------------------------------------------
# UI Configuration
# ----------------------------------------------------------------------------
# Items per page for pagination
NEXT_PUBLIC_ITEMS_PER_PAGE=20

# Video player default quality
NEXT_PUBLIC_DEFAULT_VIDEO_QUALITY=480p

# Toast notification duration in milliseconds
NEXT_PUBLIC_TOAST_DURATION=5000

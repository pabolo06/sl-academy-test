{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "./Dockerfile"
  },
  "deploy": {
    "startCommand": "python -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "healthcheckPath": "/ping",
    "healthcheckTimeout": 30,
    "numReplicas": 1
  }
}

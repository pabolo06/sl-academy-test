# ============================================================================
# SL Academy Platform - Backend Development Environment
# ============================================================================
# Configuration optimized for local development
# ============================================================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/sl_academy

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Session Configuration
SESSION_SECRET_KEY=dev-secret-key-change-in-production-32chars
SESSION_MAX_AGE=86400

# AI Configuration
OPENAI_API_KEY=sk-your-openai-key-here
AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=500
AI_TIMEOUT=10

# Rate Limiting (relaxed for development)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=10
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_TESTS=50
RATE_LIMIT_TESTS_WINDOW=3600
RATE_LIMIT_DOUBTS=20
RATE_LIMIT_DOUBTS_WINDOW=3600
RATE_LIMIT_INDICATORS=5
RATE_LIMIT_INDICATORS_WINDOW=60
RATE_LIMIT_AI=10
RATE_LIMIT_AI_WINDOW=3600

# Environment
ENVIRONMENT=development
DEBUG=true

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text
AUDIT_LOG_ENABLED=true

# File Upload
MAX_IMAGE_SIZE=5242880
MAX_SPREADSHEET_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_SPREADSHEET_TYPES=text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Security (relaxed for development)
SECURE_COOKIES=false
ENABLE_HSTS=false
HSTS_MAX_AGE=31536000
CSP_ENABLED=false

# Performance
DB_POOL_SIZE=5
DB_POOL_TIMEOUT=30
API_TIMEOUT=30
CACHE_ENABLED=false
CACHE_TTL=300

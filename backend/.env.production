# ============================================================================
# SL Academy Platform - Backend Production Environment
# ============================================================================
# CRITICAL: All values must be set via secure secrets management
# DO NOT commit this file with real values
# Use environment variables or secrets manager (AWS Secrets Manager, etc.)
# ============================================================================

# Supabase Configuration
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_ANON_KEY=your-production-anon-key-here
SUPABASE_SERVICE_KEY=your-production-service-key-here

# Database
DATABASE_URL=postgresql://postgres:password@production-db.supabase.com:6543/postgres

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# CORS Configuration
CORS_ORIGINS=https://slacademy.com,https://app.slacademy.com,https://www.slacademy.com

# Session Configuration
# CRITICAL: Generate unique 32+ character key
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=REPLACE-WITH-SECURE-GENERATED-KEY-32CHARS
SESSION_MAX_AGE=86400

# AI Configuration
OPENAI_API_KEY=sk-your-production-openai-key-here
AI_MODEL=gpt-4-turbo-preview
AI_MAX_TOKENS=500
AI_TIMEOUT=10

# Rate Limiting (strict)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_TESTS=20
RATE_LIMIT_TESTS_WINDOW=3600
RATE_LIMIT_DOUBTS=10
RATE_LIMIT_DOUBTS_WINDOW=3600
RATE_LIMIT_INDICATORS=1
RATE_LIMIT_INDICATORS_WINDOW=60
RATE_LIMIT_AI=5
RATE_LIMIT_AI_WINDOW=3600

# Environment
ENVIRONMENT=production
DEBUG=false

# Logging
LOG_LEVEL=WARNING
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true

# File Upload
MAX_IMAGE_SIZE=5242880
MAX_SPREADSHEET_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_SPREADSHEET_TYPES=text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Security (maximum security)
SECURE_COOKIES=true
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000
CSP_ENABLED=true

# Performance
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=30
API_TIMEOUT=30
CACHE_ENABLED=true
CACHE_TTL=600

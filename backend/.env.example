# ============================================================================
# SL Academy Platform - Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real credentials to version control
# See docs/ENVIRONMENT_VARIABLES.md for detailed documentation
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase Configuration
# ----------------------------------------------------------------------------
# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key for client-side operations (public, safe to expose)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key for server-side operations (KEEP SECRET!)
# This key bypasses RLS and should NEVER be exposed to clients
SUPABASE_SERVICE_KEY=your-service-key-here

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# PostgreSQL connection string for direct database access
# Format: postgresql://user:password@host:port/database
# For Supabase: Use connection pooler URL from Project Settings > Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/sl_academy

# ----------------------------------------------------------------------------
# API Server Configuration
# ----------------------------------------------------------------------------
# Host to bind the API server (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
API_HOST=0.0.0.0

# Port for the API server
API_PORT=8000

# Enable auto-reload on code changes (development only)
API_RELOAD=true

# ----------------------------------------------------------------------------
# CORS Configuration
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# Include all frontend URLs that will access this API
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ----------------------------------------------------------------------------
# Session Management
# ----------------------------------------------------------------------------
# Secret key for encrypting session cookies (MUST be 32+ characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CRITICAL: Use different keys for dev/staging/production
SESSION_SECRET_KEY=your-32-character-secret-key-here-change-this

# Session expiration time in seconds (default: 86400 = 24 hours)
SESSION_MAX_AGE=86400

# ----------------------------------------------------------------------------
# AI Service Configuration
# ----------------------------------------------------------------------------
# OpenAI API key for AI-powered features (recommendations, doubt summaries)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# AI model to use for generation
# Options: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
AI_MODEL=gpt-4-turbo-preview

# Maximum tokens for AI responses
AI_MAX_TOKENS=500

# AI request timeout in seconds
AI_TIMEOUT=10

# ----------------------------------------------------------------------------
# Rate Limiting Configuration
# ----------------------------------------------------------------------------
# Enable/disable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# Rate limit for login attempts (requests per window)
RATE_LIMIT_LOGIN=5

# Rate limit window for login (seconds)
RATE_LIMIT_LOGIN_WINDOW=900

# Rate limit for test submissions (requests per window)
RATE_LIMIT_TESTS=20

# Rate limit window for tests (seconds)
RATE_LIMIT_TESTS_WINDOW=3600

# Rate limit for doubt submissions (requests per window)
RATE_LIMIT_DOUBTS=10

# Rate limit window for doubts (seconds)
RATE_LIMIT_DOUBTS_WINDOW=3600

# Rate limit for indicator imports (requests per window)
RATE_LIMIT_INDICATORS=1

# Rate limit window for indicators (seconds)
RATE_LIMIT_INDICATORS_WINDOW=60

# Rate limit for AI requests (requests per window)
RATE_LIMIT_AI=5

# Rate limit window for AI (seconds)
RATE_LIMIT_AI_WINDOW=3600

# ----------------------------------------------------------------------------
# Environment Configuration
# ----------------------------------------------------------------------------
# Environment name: development, staging, production
ENVIRONMENT=development

# Enable debug mode (provides detailed error messages)
# MUST be false in production
DEBUG=true

# ----------------------------------------------------------------------------
# Frontend URLs (Domain Separation)
# ----------------------------------------------------------------------------
# Frontend URL for doctor domain (médico)
# Used for redirect_url in /api/auth/login/medico responses
DOCTOR_FRONTEND_URL=http://localhost:3000

# Frontend URL for manager domain (gestor)
# Used for redirect_url in /api/auth/login/gestor responses
MANAGER_FRONTEND_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=text

# Enable audit logging for security events
AUDIT_LOG_ENABLED=true

# ----------------------------------------------------------------------------
# File Upload Configuration
# ----------------------------------------------------------------------------
# Maximum file size for image uploads (bytes)
MAX_IMAGE_SIZE=5242880

# Maximum file size for spreadsheet uploads (bytes)
MAX_SPREADSHEET_SIZE=10485760

# Allowed image MIME types (comma-separated)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Allowed spreadsheet MIME types (comma-separated)
ALLOWED_SPREADSHEET_TYPES=text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------
# Enable HTTPS-only cookies (true in production)
SECURE_COOKIES=false

# Enable HSTS header (true in production)
ENABLE_HSTS=false

# HSTS max age in seconds
HSTS_MAX_AGE=31536000

# Content Security Policy
CSP_ENABLED=true

# ----------------------------------------------------------------------------
# Performance Configuration
# ----------------------------------------------------------------------------
# Database connection pool size
DB_POOL_SIZE=10

# Database connection pool timeout (seconds)
DB_POOL_TIMEOUT=30

# API request timeout (seconds)
API_TIMEOUT=30

# Enable response caching
CACHE_ENABLED=false

# Cache TTL in seconds
CACHE_TTL=300

# ----------------------------------------------------------------------------
# Redis Configuration (Caching)
# ----------------------------------------------------------------------------
# Redis host for caching layer
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis database number (0-15)
REDIS_DB=0

# Redis password (leave empty if no password)
REDIS_PASSWORD=

# Redis connection timeout (seconds)
REDIS_TIMEOUT=5

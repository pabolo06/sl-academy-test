# ============================================================================
# SL Academy Platform - Backend Staging Environment
# ============================================================================
# Configuration for staging/testing environment
# Should mirror production settings but with separate resources
# ============================================================================

# Supabase Configuration
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-key-here
SUPABASE_SERVICE_KEY=your-staging-service-key-here

# Database
DATABASE_URL=postgresql://postgres:password@staging-db.supabase.com:6543/postgres

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# CORS Configuration
CORS_ORIGINS=https://staging.slacademy.com,https://staging-app.slacademy.com

# Session Configuration
SESSION_SECRET_KEY=staging-secret-key-generate-unique-32chars
SESSION_MAX_AGE=86400

# AI Configuration
OPENAI_API_KEY=sk-your-staging-openai-key-here
AI_MODEL=gpt-4-turbo-preview
AI_MAX_TOKENS=500
AI_TIMEOUT=10

# Rate Limiting (production-like)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_TESTS=20
RATE_LIMIT_TESTS_WINDOW=3600
RATE_LIMIT_DOUBTS=10
RATE_LIMIT_DOUBTS_WINDOW=3600
RATE_LIMIT_INDICATORS=1
RATE_LIMIT_INDICATORS_WINDOW=60
RATE_LIMIT_AI=5
RATE_LIMIT_AI_WINDOW=3600

# Environment
ENVIRONMENT=staging
DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true

# File Upload
MAX_IMAGE_SIZE=5242880
MAX_SPREADSHEET_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_SPREADSHEET_TYPES=text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Security (production-like)
SECURE_COOKIES=true
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000
CSP_ENABLED=true

# Performance
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=30
API_TIMEOUT=30
CACHE_ENABLED=true
CACHE_TTL=300

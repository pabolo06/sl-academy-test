# SL Academy Platform - Git Ignore

# Environment variables - NEVER commit these files!
# Only .env.example files should be committed
.env
.env.local
.env.*.local
*.env

# Specific environment files (keep .env.example, .env.development, .env.staging, .env.production as templates)
# But ignore any .env files that might contain real credentials
backend/.env
backend/.env.local
frontend/.env.local


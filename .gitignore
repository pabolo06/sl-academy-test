# SL Academy Platform - Git Ignore

# ============================================================================
# CRITICAL: Environment Variables - NEVER commit these files!
# ============================================================================
# Only .env.example, .env.development, .env.staging, .env.production should be committed
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local

